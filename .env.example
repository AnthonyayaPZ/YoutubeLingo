# Copy this file to `.env` and fill your keys.
# .env is loaded automatically when running `uv run python main.py ...`

# OpenAI translation (used when --translator_backend=openai or auto fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepL translation (used when --translator_backend=deepl or auto priority)
DEEPL_API_KEY=
