# Copy this file to `.env` and fill your keys.
# .env is loaded automatically when running `uv run python main.py ...`

# OpenAI translation (used when --translator_backend=openai or auto fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
# Optional: send multiple parallel OpenAI requests for the same text and use the first success.
# Higher value = lower tail-latency, higher token cost. Default is 1.
OPENAI_PARALLEL_REQUESTS=1

# DeepL translation (used when --translator_backend=deepl or auto priority)
DEEPL_API_KEY=

# Optional yt-dlp cookies for YouTube access (main pipeline)
# Choose one strategy:
# 1) Browser cookies:
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_BROWSER_PROFILE=Default
# 2) cookies.txt file:
# YTDLP_COOKIES_FILE=./demo/www.youtube.com_cookies.txt
